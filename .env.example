APP_NAME=Laravel12Vue3
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database Configuration
# Option 1: SQLite (Recommended for development)
DB_CONNECTION=sqlite
DB_DATABASE=database.sqlite

# Option 2: MySQL (For production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel_vue3
# DB_USERNAME=root
# DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_TTL=60
JWT_REFRESH_TTL=20160

# Vite Configuration
VITE_API_URL=/api
